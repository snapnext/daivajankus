# Public production URL — used for canonical / sitemap / OG / robots metadata.
# Set this on Vercel BEFORE going live so structured data points at the real domain.
# No trailing slash. The default if unset is "https://daivajankus.de".
NEXT_PUBLIC_SITE_URL=https://daivajankus.de

# Resend (https://resend.com) — used by the contact form Server Action.
# Required in production. The form falls back to a "no-op success" if RESEND_API_KEY is absent,
# which lets you preview the page locally without leaking keys.
RESEND_API_KEY=re_xxx_replace_me

# The "From" header. Either a bare email or "Name <email@domain>" — NO surrounding quotes.
#   bare:   anfrage@daiva-jankus.de
#   named:  Daiva Jankus <anfrage@daiva-jankus.de>
# IMPORTANT: When pasting into Vercel / Netlify / etc., do NOT include the surrounding
# quotes you see in this file — those are .env-syntax only. Hosting UIs treat the literal
# string as the value and Resend will reject it with "Invalid from field".
# The domain must be VERIFIED in Resend → Domains. Until verified, use the open sender
# Resend provides:
#   onboarding@resend.dev
RESEND_FROM=Daiva Jankus <anfrage@daiva-jankus.de>

# Where contact-form submissions are delivered.
# Single address, or comma-separated list to deliver to multiple inboxes.
# Example: RESEND_TO=daivajankus@t-online.de,max@snapnext.de
RESEND_TO=daivajankus@t-online.de
